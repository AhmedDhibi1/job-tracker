# Database connection
DB_URL=jdbc:postgresql://localhost:5432/jobtracker
DB_USERNAME=jobtracker
DB_PASSWORD=change_me
DB_NAME=jobtracker
DB_PORT=5432

# Encryption keys (base64-encoded 256-bit keys)
